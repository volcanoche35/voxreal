generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  emailVerified   DateTime?
  name            String?
  displayName     String?
  image           String?
  passwordHash    String?
  authProviderId  String?  @unique
  trustScore      Int      @default(50)
  tokenBalance    Float    @default(0)
  isVerified      Boolean  @default(false)
  deviceFingerprint String?
  createdAt       DateTime @default(now())
  lastActiveAt    DateTime @default(now())

  accounts    Account[]
  sessions    Session[]
  interests     UserInterest[]
  votes         Vote[]
  polls         Poll[]
  trustLogs     TrustLog[]
  userBadges    UserBadge[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String?
  parentId  String?
  parent    Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryParent")
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  polls         Poll[]
  userInterests UserInterest[]
}

model UserInterest {
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  weight     Float    @default(1.0)
  createdAt  DateTime @default(now())

  @@id([userId, categoryId])
}

model Poll {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  categoryId   String
  category     Category  @relation(fields: [categoryId], references: [id])
  question     String
  options      String    // JSON: [{id:"a", text:"..."}, ...]
  pollType     String    @default("single")
  duration     Int       @default(86400) // seconds
  status       String    @default("active") // active, closed, archived
  targetFilter String?   // JSON: {minAge, maxAge, gender, regions}
  totalVotes   Int       @default(0)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime

  votes Vote[]
}

model Vote {
  id                   String   @id @default(cuid())
  pollId               String
  poll                 Poll     @relation(fields: [pollId], references: [id])
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  selectedOption       String
  userTrustScoreAtTime Int
  responseTimeMs       Int?
  ipAddress            String?
  deviceFingerprint    String?
  createdAt            DateTime @default(now())

  @@unique([pollId, userId])
}

model TrustLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int
  reason      String
  pollId      String?
  createdAt   DateTime @default(now())
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String?
  icon        String?
  threshold   Int
  createdAt   DateTime    @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  awardedAt DateTime @default(now())

  @@id([userId, badgeId])
}
